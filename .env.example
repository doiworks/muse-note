# Supabase Project URL（Project Settings -> API から取得）
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Anon Key（公開用キー）
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase Service Role Key（サーバー専用。絶対に公開しない）
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key


# 開発確認用の仮ログイントークン（サーバー専用。NEXT_PUBLIC_ は付けない）
ADMIN_PREVIEW_TOKEN=replace-with-a-long-random-token

# 将来LINE Loginを追加するとき用
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
LINE_REDIRECT_URI=http://localhost:3000/api/auth/line/callback
