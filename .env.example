# Supabase Project URL（Project Settings -> API から取得）
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Anon Key（公開用キー）
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase Service Role Key（サーバー専用。絶対に公開しない）
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ログインCookieの署名用。長いランダム文字列を設定する
APP_SESSION_SECRET=replace-with-a-long-random-secret

# 開発確認用の仮ログイントークン（本番の一般利用者には知らせない）
ADMIN_PREVIEW_TOKEN=replace-with-a-long-random-token

# LINE Developers の LINE Login チャネル設定
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
LINE_REDIRECT_URI=http://localhost:3000/api/auth/line/callback
