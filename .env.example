# Supabase Project URL（Project Settings -> API から取得）
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Anon Key（公開用キー）
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase Service Role Key（サーバー専用。絶対に公開しない）
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 開発確認用の一時的な管理者トークン
# 例: http://localhost:3000?preview_token=your-secret-preview-token
ADMIN_PREVIEW_TOKEN=your-secret-preview-token

# 将来LINE Loginを追加するとき用
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
LINE_REDIRECT_URI=http://localhost:3000/api/auth/line/callback
